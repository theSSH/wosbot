# Normalize line endings for text sources; keep Windows scripts CRLF.
* text=auto eol=lf
*.bat text eol=crlf

# Large native binaries and OCR data are stored via Git LFS to keep the
# regular Git history small and fast to clone.
*.exe filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.traineddata filter=lfs diff=lfs merge=lfs -text
